# =============================================
# FIXELO - Coolify Dockerfile Deployment
# =============================================
# Use this when the Coolify resource type is Dockerfile / Docker Image.
# In this mode, the app container must receive DATABASE_URL directly.

# Application URLs
NEXT_PUBLIC_APP_URL=https://fixelo.app
NEXTAUTH_URL=https://fixelo.app

# Auth
NEXTAUTH_SECRET=generate_a_long_random_secret_here
AUTH_TRUST_HOST=true

# Database
# Replace host, user, password and database with your actual PostgreSQL resource values.
DATABASE_URL=postgresql://fixelo:change_me@postgres:5432/fixelo_prod?schema=public

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMTP / Email
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@fixelo.app
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=no-reply@fixelo.app
EMAIL_FROM=no-reply@fixelo.app
SUPPORT_EMAIL=support@fixelo.app

# Optional: Resend
RESEND_API_KEY=re_your_resend_api_key

# Optional: Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Optional: Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Optional: Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: S3 Uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=fixelo-uploads